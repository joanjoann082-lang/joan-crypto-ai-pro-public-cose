from __future__ import annotations

import os
import re
import shutil
import subprocess
from datetime import datetime
from pathlib import Path


ROOT = Path(".").resolve()
HUB = ROOT / "joanbot/market/hub.py"
DB = ROOT / "joanbot/storage/db.py"
POLICY = ROOT / "joanbot/storage/storage_policy_v29.py"
MIGRATION = ROOT / "scripts/migrate_storage_v29.py"
RUNNER = ROOT / "scripts/run_v29_safe.sh"


def ts() -> str:
    return datetime.now().strftime("%Y%m%d_%H%M%S")


def die(msg: str) -> None:
    raise SystemExit(f"ERROR: {msg}")


def ensure_project() -> None:
    if not HUB.exists():
        die(f"Missing {HUB}")
    if not DB.exists():
        die(f"Missing {DB}")
    if not (ROOT / "data/joanbot_v14.sqlite").exists():
        die("Missing data/joanbot_v14.sqlite")


def ensure_no_runner() -> None:
    out = subprocess.run(
        "ps -ef | grep python | grep -v grep || true",
        shell=True,
        text=True,
        capture_output=True,
    ).stdout.strip()

    if out:
        print("WARNING: Python processes detected:")
        print(out)
        die("Stop runners before installing storage layer.")


def backup_code() -> Path:
    b = ROOT / "backups" / f"code_storage_v29_{ts()}"
    b.mkdir(parents=True, exist_ok=True)
    shutil.copy2(HUB, b / "hub.py.bak")
    shutil.copy2(DB, b / "db.py.bak")
    return b


