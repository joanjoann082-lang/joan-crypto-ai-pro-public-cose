def patch_hub() -> None:
    s = HUB.read_text()

    if "storage_policy_v29 import persist_market_snapshot" not in s:
        lines = s.splitlines()
        insert_at = 0
        for i, line in enumerate(lines[:80]):
            if line.startswith("import ") or line.startswith("from "):
                insert_at = i + 1

        lines.insert(insert_at, "from joanbot.storage.storage_policy_v29 import persist_market_snapshot")
        s = "\n".join(lines) + "\n"

    pattern = re.compile(
        r"self\.db\.insert_json\(\s*['\"]market_snapshots['\"]\s*,\s*snap\s*,\s*\{[^{}]*?['\"]price['\"]\s*:\s*price[^{}]*?\}\s*\)"
    )

    replacement = 'persist_market_snapshot(self.db, symbol, snap, price, reason="scheduled")'

    s2, n = pattern.subn(replacement, s, count=1)

    if n == 0 and replacement not in s:
        die("Could not patch hub.py market_snapshots insert. Manual inspection required.")

    HUB.write_text(s2)
    print("PATCHED hub.py")


def patch_db_guard() -> None:
    s = DB.read_text()

    if "DB_PAYLOAD_GUARD_V29" not in s:
        marker = "\nclass DB:"
        if marker not in s:
            die("class DB not found in db.py")

        helper = r'''
# === DB_PAYLOAD_GUARD_V29 ===
def _v29_payload_guard(table, obj):
    if table != "market_snapshots":
        return obj

    try:
        import json as _json_v29
        from joanbot.storage.storage_policy_v29 import compact_market_snapshot

        max_bytes = int(__import__("os").getenv("JOANBOT_SQLITE_MARKET_PAYLOAD_MAX_BYTES", "60000"))
        raw = _json_v29.dumps(obj, ensure_ascii=False, sort_keys=True).encode("utf-8")

        if len(raw) <= max_bytes:
            return obj

        if isinstance(obj, dict):
            return compact_market_snapshot(obj)

        return {
            "compact": True,
            "schema": "market_snapshot_non_dict_guard_v29",
            "type": type(obj).__name__,
        }
    except Exception:
        return {
            "compact": True,
            "schema": "market_snapshot_guard_exception_v29",
            "type": type(obj).__name__,
        }
# === END_DB_PAYLOAD_GUARD_V29 ===

'''
        s = s.replace(marker, "\n" + helper + "class DB:", 1)

    old = "json.dumps(obj, ensure_ascii=False, sort_keys=True)"
    new = "json.dumps(_v29_payload_guard(table, obj), ensure_ascii=False, sort_keys=True)"

    if new not in s:
        if old not in s:
            die("Could not find json.dumps(obj...) in db.py insert_json")
        s = s.replace(old, new, 1)

    DB.write_text(s)
    print("PATCHED db.py guard")


def write_migration() -> None:
    MIGRATION.write_text(r'''from __future__ import annotations

import gzip
import hashlib
import json
import sqlite3
import time
from datetime import datetime, timezone
from pathlib import Path

from joanbot.storage.storage_policy_v29 import compact_market_snapshot, detect_archive_root


DB = Path("data/joanbot_v14.sqlite")
KEEP_PER_SYMBOL = 300


def gb(n: int) -> float:
    return round(n / 1024**3, 3)


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def parse_payload(raw: str):
    try:
        return json.loads(raw)
    except Exception:
        return {
            "compact": True,
            "schema": "unparseable_payload_v29",
            "raw_len": len(raw or ""),
        }


def main() -> None:
    if not DB.exists():
        raise SystemExit(f"DB_NOT_FOUND: {DB}")

    root = detect_archive_root()
    mig_dir = root / "migrations"
    mig_dir.mkdir(parents=True, exist_ok=True)

    ts = datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")
    export_path = mig_dir / f"market_snapshots_full_export_before_prune_{ts}.jsonl.gz"

    print("=== STORAGE V29 MIGRATION ===")
    print("DB:", DB)
    print("DB_SIZE_BEFORE_GB:", gb(DB.stat().st_size))
    print("ARCHIVE_ROOT:", root)
    print("EXPORT:", export_path)

    con = sqlite3.connect(str(DB), timeout=120)
    con.row_factory = sqlite3.Row

    total = con.execute("SELECT COUNT(*) c FROM market_snapshots").fetchone()["c"]
    meta = con.execute(
        "SELECT MIN(ts) min_ts, MAX(ts) max_ts, COUNT(DISTINCT symbol) symbols FROM market_snapshots"
    ).fetchone()

    print("ROWS_BEFORE:", total)
    print("MIN_TS:", meta["min_ts"])
    print("MAX_TS:", meta["max_ts"])
    print("SYMBOLS:", meta["symbols"])

    print("EXPORT_START")
    t0 = time.time()
    count = 0

    with gzip.open(export_path, "wt", encoding="utf-8", compresslevel=6) as out:
        cur = con.execute("SELECT id, ts, symbol, price, payload FROM market_snapshots ORDER BY id")
        for r in cur:
            payload = str(r["payload"] or "null").strip()

            prefix = json.dumps(
                {
                    "id": r["id"],
                    "ts": r["ts"],
                    "symbol": r["symbol"],
                    "price": r["price"],
                },
                ensure_ascii=False,
                separators=(",", ":"),
            )

            out.write(prefix[:-1])
            out.write(',"payload":')

            if payload.startswith("{") or payload.startswith("["):
                out.write(payload)
            else:
                out.write(json.dumps(payload, ensure_ascii=False))

            out.write("}\n")

            count += 1
            if count % 1000 == 0:
                print("exported", count, "/", total)

    print("EXPORT_DONE:", count)
    print("EXPORT_SECONDS:", round(time.time() - t0, 1))
    print("EXPORT_SIZE_GB:", gb(export_path.stat().st_size))

    print("VERIFY_START")
    verify = 0
    with gzip.open(export_path, "rt", encoding="utf-8") as f:
        for _ in f:
            verify += 1

    print("VERIFY_LINES:", verify)

    if verify != total:
        raise SystemExit(f"VERIFY_FAILED {verify} != {total}")

    sha = sha256_file(export_path)
    manifest = {
        "created_at": datetime.now(timezone.utc).isoformat(),
        "schema": "storage_v29_migration_manifest",
        "source_db": str(DB),
        "source_db_size_gb_before": gb(DB.stat().st_size),
        "rows_exported": count,
        "rows_verified": verify,
        "min_ts": meta["min_ts"],
        "max_ts": meta["max_ts"],
        "distinct_symbols": meta["symbols"],
        "export_file": str(export_path),
        "export_size_bytes": export_path.stat().st_size,
        "sha256": sha,
        "keep_per_symbol_after_prune": KEEP_PER_SYMBOL,
    }

    manifest_path = export_path.with_suffix(export_path.suffix + ".manifest.json")
    manifest_path.write_text(json.dumps(manifest, indent=2, ensure_ascii=False))

    print("MANIFEST:", manifest_path)
    print("SHA256:", sha)

    print("BUILD_KEEP_SET")
    con.execute("DROP TABLE IF EXISTS temp.keep_market_ids")
    con.execute("CREATE TEMP TABLE keep_market_ids (id INTEGER PRIMARY KEY)")

    symbols = [r["symbol"] for r in con.execute("SELECT DISTINCT symbol FROM market_snapshots WHERE symbol IS NOT NULL")]

    keep_ids = []
    for sym in symbols:
        rows = con.execute(
            """
            SELECT id
            FROM market_snapshots
            WHERE symbol=?
            ORDER BY id DESC
            LIMIT ?
            """,
            (sym, KEEP_PER_SYMBOL),
        ).fetchall()
        keep_ids.extend([r["id"] for r in rows])

    con.executemany("INSERT OR IGNORE INTO keep_market_ids(id) VALUES (?)", [(i,) for i in keep_ids])
    con.commit()

    print("KEEP_IDS:", len(set(keep_ids)))

    print("COMPACT_REMAINING_ROWS")
    cur = con.execute(
        """
        SELECT id, payload
        FROM market_snapshots
        WHERE id IN (SELECT id FROM keep_market_ids)
        """
    )

    updates = []
    for r in cur:
        payload = parse_payload(r["payload"] or "")
        if isinstance(payload, dict):
            compact = compact_market_snapshot(payload)
        else:
            compact = {
                "compact": True,
                "schema": "non_dict_remaining_payload_v29",
            }

        updates.append((json.dumps(compact, ensure_ascii=False, sort_keys=True), r["id"]))

    con.executemany("UPDATE market_snapshots SET payload=? WHERE id=?", updates)
    con.commit()

    print("DELETE_OLD_ROWS_START")
    con.execute("DELETE FROM market_snapshots WHERE id NOT IN (SELECT id FROM keep_market_ids)")
    con.commit()

    print("COUNTS_AFTER_DELETE:")
    for r in con.execute("SELECT symbol, COUNT(*) c, MIN(ts) min_ts, MAX(ts) max_ts FROM market_snapshots GROUP BY symbol"):
        print(dict(r))

    print("CHECKPOINT")
    try:
        con.execute("PRAGMA wal_checkpoint(TRUNCATE);")
    except Exception:
        pass

    print("VACUUM_START")
    t1 = time.time()
    con.execute("VACUUM;")
    con.execute("PRAGMA optimize;")
    con.close()

    print("VACUUM_SECONDS:", round(time.time() - t1, 1))
    print("DB_SIZE_AFTER_GB:", gb(DB.stat().st_size))
    print("STORAGE_V29_MIGRATION_OK")


if __name__ == "__main__":
    main()

