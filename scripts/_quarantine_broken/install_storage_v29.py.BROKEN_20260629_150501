import gzip
import hashlib
import json
import os
import shutil
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Optional


VERSION = "STORAGE_POLICY_V29_INSTITUTIONAL"


_RAW_LAST_ARCHIVE: dict[str, float] = {}
_LAST_PRUNE: dict[str, float] = {}


def utc_now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()


def _safe_float(x: Any, default: float = 0.0) -> float:
    try:
        if x is None:
            return default
        return float(x)
    except Exception:
        return default


def _safe_int(x: Any, default: int = 0) -> int:
    try:
        if x is None:
            return default
        return int(float(x))
    except Exception:
        return default


def free_gb(path: Path | str = ".") -> float:
    try:
        u = shutil.disk_usage(str(path))
        return u.free / 1024**3
    except Exception:
        return 0.0


def _is_writable(path: Path) -> bool:
    try:
        path.mkdir(parents=True, exist_ok=True)
        probe = path / ".storage_v29_probe"
        probe.write_text("ok")
        probe.unlink(missing_ok=True)
        return True
    except Exception:
        return False


def detect_archive_root() -> Path:
    env = os.getenv("JOANBOT_ARCHIVE_DIR")
    candidates: list[Path] = []

    if env:
        candidates.append(Path(env))

    candidates.extend([
        Path("/storage/80A3-16F9/joanbot_archive"),
        Path("/sdcard/joanbot_archive"),
        Path("data/cold_archive"),
    ])

    for c in candidates:
        if _is_writable(c):
            return c

    fallback = Path("data/cold_archive")
    fallback.mkdir(parents=True, exist_ok=True)
    return fallback


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def compact_candle(c: Any) -> dict[str, Any]:
    if not isinstance(c, dict):
        return {}

    return {
        "open_time": c.get("open_time"),
        "close_time": c.get("close_time"),
        "open": _safe_float(c.get("open")),
        "high": _safe_float(c.get("high")),
        "low": _safe_float(c.get("low")),
        "close": _safe_float(c.get("close")),
        "volume": _safe_float(c.get("volume")),
        "quote_volume": _safe_float(c.get("quote_volume")),
        "trades": _safe_int(c.get("trades")),
        "taker_buy_base": _safe_float(c.get("taker_buy_base")),
        "taker_buy_quote": _safe_float(c.get("taker_buy_quote")),
    }


def compact_market_snapshot(snap: dict[str, Any]) -> dict[str, Any]:
    candles = snap.get("candles") or {}
    candles_last: dict[str, Any] = {}

    if isinstance(candles, dict):
        for timeframe, rows in candles.items():
            if isinstance(rows, list) and rows:
                candles_last[str(timeframe)] = compact_candle(rows[-1])

    ticker = snap.get("ticker") or {}
    derivatives = snap.get("derivatives") or {}
    orderbook = snap.get("orderbook") or {}
    trades = snap.get("trades") or {}
    liq = snap.get("liquidations") or {}

    return {
        "compact": True,
        "schema": "market_snapshot_compact_v29",
        "ts": snap.get("ts"),
        "symbol": snap.get("symbol"),
        "price": _safe_float(snap.get("price")),
        "ticker": {
            "price": _safe_float(ticker.get("price")),
            "price_change_pct": _safe_float(ticker.get("priceChangePercent")),
            "volume": _safe_float(ticker.get("volume")),
            "quote_volume": _safe_float(ticker.get("quoteVolume")),
        },
        "candles_last": candles_last,
        "derivatives": {
            "funding_rate": _safe_float(derivatives.get("funding_rate")),
            "open_interest": _safe_float(derivatives.get("open_interest")),
            "oi_chg_5m": _safe_float(derivatives.get("oi_chg_5m")),
            "oi_chg_1h": _safe_float(derivatives.get("oi_chg_1h")),
            "long_short_ratio": _safe_float(derivatives.get("long_short_ratio")),
            "top_long_short_ratio": _safe_float(derivatives.get("top_long_short_ratio")),
            "taker_buy_ratio": _safe_float(derivatives.get("taker_buy_sell_ratio")),
            "basis_bps": _safe_float(derivatives.get("basis_bps")),
        },
        "orderflow": {
            "spread_bps": _safe_float(orderbook.get("spread_bps")),
            "depth_10bps": _safe_float(orderbook.get("depth_10bps")),
            "depth_25bps": _safe_float(orderbook.get("depth_25bps")),
            "imbalance_25bps": _safe_float(orderbook.get("imbalance_25bps")),
            "wall_pressure": _safe_float(orderbook.get("wall_pressure")),
            "cvd_proxy": _safe_float(trades.get("cvd_proxy")),
        },
        "liquidations": {
            "count": len(liq) if isinstance(liq, list) else 0,
        },
    }


def archive_raw_market_snapshot(symbol: str, snap: dict[str, Any], reason: str = "scheduled") -> Optional[Path]:
    enabled = os.getenv("JOANBOT_ARCHIVE_RAW_MARKET", "1").lower() not in {"0", "false", "no", "off"}
    if not enabled:
        return None

    min_free_gb = float(os.getenv("JOANBOT_ARCHIVE_MIN_FREE_GB", "5"))
    archive_root = detect_archive_root()

    if free_gb(archive_root) < min_free_gb:
        return None

    day = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    safe_symbol = "".join(ch for ch in str(symbol) if ch.isalnum() or ch in "_-")
    d = archive_root / "market_snapshots" / day
    d.mkdir(parents=True, exist_ok=True)

    path = d / f"{safe_symbol}.jsonl.gz"
    record = {
        "archived_at": utc_now_iso(),
        "schema": "raw_market_snapshot_v29",
        "reason": reason,
        "symbol": symbol,
        "payload": snap,
    }

    with gzip.open(path, "at", encoding="utf-8", compresslevel=6) as f:
        f.write(json.dumps(record, ensure_ascii=False, separators=(",", ":")))
        f.write("\n")

    return path


def should_archive_raw(symbol: str, reason: str = "scheduled") -> bool:
    if reason != "scheduled":
        return True

    interval = int(os.getenv("JOANBOT_RAW_MARKET_INTERVAL_SEC", "1800"))
    interval = max(300, min(interval, 21600))

    now = time.time()
    last = _RAW_LAST_ARCHIVE.get(symbol, 0.0)

    if now - last >= interval:
        _RAW_LAST_ARCHIVE[symbol] = now
        return True

    return False


def prune_market_snapshots(db: Any, symbol: str) -> None:
    interval = int(os.getenv("JOANBOT_MARKET_PRUNE_INTERVAL_SEC", "300"))
    now = time.time()
    last = _LAST_PRUNE.get(symbol, 0.0)

    if now - last < interval:
        return

    _LAST_PRUNE[symbol] = now

    keep = int(os.getenv("JOANBOT_MARKET_SNAPSHOT_KEEP_PER_SYMBOL", "300"))
    keep = max(50, min(keep, 2000))

    db.execute(
        """
        DELETE FROM market_snapshots
        WHERE symbol=?
          AND id NOT IN (
            SELECT id
            FROM market_snapshots
            WHERE symbol=?
            ORDER BY id DESC
            LIMIT ?
          )
        """,
        (symbol, symbol, keep),
    )


def enforce_payload_limit(payload: dict[str, Any]) -> dict[str, Any]:
    max_bytes = int(os.getenv("JOANBOT_SQLITE_MARKET_PAYLOAD_MAX_BYTES", "60000"))

    try:
        size = len(json.dumps(payload, ensure_ascii=False, sort_keys=True).encode("utf-8"))
    except Exception:
        return {
            "compact": True,
            "schema": "market_snapshot_payload_error_v29",
        }

    if size <= max_bytes:
        return payload

    return compact_market_snapshot(payload)


def persist_market_snapshot(db: Any, symbol: str, snap: dict[str, Any], price: float, reason: str = "scheduled") -> None:
    """
    Main institutional storage entrypoint.

    Keeps full live snapshot available for strategy in memory.
    Writes only compact payload to hot SQLite.
    Archives raw full payload out of SQLite on a controlled schedule.
    Applies hard retention to prevent storage death.
    """
    symbol = str(symbol)

    if should_archive_raw(symbol, reason=reason):
        try:
            archive_raw_market_snapshot(symbol, snap, reason=reason)
        except Exception:
            pass

    compact = compact_market_snapshot(snap)
    compact = enforce_payload_limit(compact)

    db.insert_json(
        "market_snapshots",
        compact,
        {
            "ts": snap.get("ts"),
            "symbol": symbol,
            "price": price,
        },
    )

    try:
        prune_market_snapshots(db, symbol)
    except Exception:
        pass
''')

