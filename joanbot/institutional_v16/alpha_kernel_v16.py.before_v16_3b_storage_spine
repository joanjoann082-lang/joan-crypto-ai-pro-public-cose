    def refresh_labels(self, cur):
        inserted = 0

        if not self.exists(cur, "paper_micro_canary_positions_v11"):
            return {"inserted": inserted, "state": "NO_V11_CANARY_TABLE"}

        rows = cur.execute("""
            SELECT *
            FROM paper_micro_canary_positions_v11
            WHERE status='CLOSED' OR closed_at IS NOT NULL;
        """).fetchall()

        c = self.cols(cur, "paper_micro_canary_positions_v11")

        for r in rows:
            d = dict(r)
            sid = d.get("id")

            if sid is None:
                continue

            already = cur.execute("""
                SELECT COUNT(*)
                FROM canonical_r_labels_v16
                WHERE source_table='paper_micro_canary_positions_v11'
                  AND source_id=?;
            """, (sid,)).fetchone()[0]

            if already:
                continue

            side = str(d.get("side") or "").upper()
            entry = f(d.get("entry_price"))
            exitp = f(d.get("exit_price"))
            size = f(d.get("size_usd"))
            risk = f(d.get("risk_usd"))
            gross = f(d.get("gross_usd"))
            fees = f(d.get("fees_usd"))
            net = f(d.get("net_usd") or d.get("pnl_usd"))

            if "net_pnl_r" in c and d.get("net_pnl_r") is not None:
                r_value = f(d.get("net_pnl_r"))
                quality = "DIRECT_NET_PNL_R"
            else:
                if not gross and entry and exitp and size:
                    if side == "LONG":
                        gross = size * ((exitp - entry) / entry)
                    elif side == "SHORT":
                        gross = size * ((entry - exitp) / entry)
                if not fees:
                    fees = size * 0.0008
                if not net:
                    net = gross - fees
                if not risk:
                    risk = size * 0.012
                r_value = net / risk if risk > 0 else 0.0
                quality = "REBUILT_FROM_EXECUTION_FIELDS"

            cur.execute("""
                INSERT INTO canonical_r_labels_v16 (
                    ts, version, source_table, source_id, symbol, side, setup,
                    profile, horizon_min, opened_at, closed_at, entry_price,
                    exit_price, size_usd, risk_usd, gross_usd, fees_usd,
                    net_usd, canonical_r, label_quality, reason, payload
                )
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);
            """, (
                now_iso(), VERSION, "paper_micro_canary_positions_v11", sid,
                d.get("symbol"), side, d.get("setup"), d.get("profile"),
                nint(d.get("horizon_min")), d.get("opened_at"), d.get("closed_at"),
                entry, exitp, size, risk, gross, fees, net, r_value,
                quality, d.get("reason"), js(d),
            ))

            inserted += 1

        return {"inserted": inserted, "state": "OK"}

    def rebuild_training_matrix(self, cur):
        if not self.exists(cur, "canonical_r_labels_v16"):
            return {"inserted": 0, "state": "NO_LABELS"}

        rows = cur.execute("""
            SELECT *
            FROM canonical_r_labels_v16
            ORDER BY id ASC
            LIMIT 5000;
        """).fetchall()

        inserted = 0

        for r in rows:
            d = dict(r)
            label_id = d.get("id")

            already = cur.execute("""
                SELECT COUNT(*)
                FROM alpha_training_matrix_v16
                WHERE label_id=?;
            """, (label_id,)).fetchone()[0]

            if already:
                continue

            symbol = d.get("symbol")
            side = d.get("side")
            opened = parse_dt(d.get("opened_at"))

            fs = None
            temporal_quality = "NO_FEATURE_SNAPSHOT"

            if opened and self.exists(cur, "alpha_feature_store_v16"):
                row = cur.execute("""
                    SELECT *
                    FROM alpha_feature_store_v16
                    WHERE symbol=? AND side=? AND ts<=?
                    ORDER BY ts DESC
                    LIMIT 1;
                """, (symbol, side, opened.isoformat())).fetchone()

                if row:
                    fs = dict(row)
                    temporal_quality = "PRE_OPEN_FEATURE"
                else:
                    row = cur.execute("""
                        SELECT *
                        FROM alpha_feature_store_v16
                        WHERE symbol=? AND side=?
                        ORDER BY id DESC
                        LIMIT 1;
                    """, (symbol, side)).fetchone()
                    if row:
                        fs = dict(row)
                        temporal_quality = "LATEST_FEATURE_FALLBACK"

            fs = fs or {}

            cur.execute("""
                INSERT INTO alpha_training_matrix_v16 (
                    ts, version, label_id, symbol, side, setup, profile,
                    horizon_min, canonical_r, funding_rate, open_interest,
                    spread_bps, imbalance_20, liquidation_15m_usd,
                    liquidation_signed_15m_usd, derivatives_confidence,
                    feature_temporal_quality, payload
                )
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);
            """, (
                now_iso(), VERSION, label_id, symbol, side, d.get("setup"),
                d.get("profile"), d.get("horizon_min"), f(d.get("canonical_r")),
                f(fs.get("funding_rate")), f(fs.get("open_interest")),
                f(fs.get("spread_bps")), f(fs.get("imbalance_20")),
                f(fs.get("liquidation_15m_usd")),
                f(fs.get("liquidation_signed_15m_usd")),
                f(fs.get("derivatives_confidence")),
                temporal_quality,
                js({"label": d, "feature": fs}),
            ))

            inserted += 1

        return {"inserted": inserted, "state": "OK"}

