        """, (now_iso(), VERSION, source, status, quality, js(payload)))

    def fetch_binance_public(self, symbol):
        base = "https://fapi.binance.com"
        premium = get_json(f"{base}/fapi/v1/premiumIndex?symbol={symbol}")
        oi = get_json(f"{base}/fapi/v1/openInterest?symbol={symbol}")
        depth = get_json(f"{base}/fapi/v1/depth?symbol={symbol}&limit=100")

        bids = [(float(p), float(q)) for p, q in depth.get("bids", [])]
        asks = [(float(p), float(q)) for p, q in depth.get("asks", [])]

        best_bid = bids[0][0] if bids else 0.0
        best_ask = asks[0][0] if asks else 0.0
        mid = (best_bid + best_ask) / 2 if best_bid and best_ask else 0.0
        spread_bps = ((best_ask - best_bid) / mid * 10000.0) if mid else 0.0

        bid5 = sum(p * q for p, q in bids[:5])
        ask5 = sum(p * q for p, q in asks[:5])
        bid20 = sum(p * q for p, q in bids[:20])
        ask20 = sum(p * q for p, q in asks[:20])

        imb5 = (bid5 - ask5) / max(bid5 + ask5, 1.0)
        imb20 = (bid20 - ask20) / max(bid20 + ask20, 1.0)

        if imb20 > 0.12:
            pressure = "BID_DEPTH_DOMINANT"
        elif imb20 < -0.12:
            pressure = "ASK_DEPTH_DOMINANT"
        else:
            pressure = "BALANCED_DEPTH"

        return {
            "mark_price": f(premium.get("markPrice")),
            "index_price": f(premium.get("indexPrice")),
            "funding_rate": f(premium.get("lastFundingRate")),
            "open_interest": f(oi.get("openInterest")),
            "spread_bps": spread_bps,
            "imbalance_5": imb5,
            "imbalance_20": imb20,
            "bid_depth_20": bid20,
            "ask_depth_20": ask20,
            "depth_pressure": pressure,
            "raw": {"premium": premium, "oi": oi},
        }

    def liquidation_aggregate(self, cur, symbol):
        tables = []
        if self.exists(cur, "liquidation_events_v16"):
            tables.append("liquidation_events_v16")
        if self.exists(cur, "liquidation_events_v14"):
            tables.append("liquidation_events_v14")

        if not tables:
            return {
                "liq_5m": 0.0,
                "liq_15m": 0.0,
                "liq_60m": 0.0,
                "signed_15m": 0.0,
                "pressure": "LIQUIDATIONS_UNAVAILABLE",
            }

        rows = []
        for t in tables:
            try:
                rows += [dict(r) for r in cur.execute(
                    f"""
                    SELECT ts, symbol, side, notional_usd
                    FROM {t}
                    WHERE symbol=?
                    ORDER BY id DESC
                    LIMIT 2000;
                    """,
                    (symbol,),
                ).fetchall()]
            except Exception:
                pass

        now = datetime.now(timezone.utc)
        liq5 = liq15 = liq60 = signed15 = 0.0

        for r in rows:
            d = parse_dt(r.get("ts"))
            if not d:
                continue
            mins = (now - d).total_seconds() / 60.0
            notional = f(r.get("notional_usd"))
            side = str(r.get("side") or "").upper()

            # SELL forceOrder = long liquidation pressure. BUY = short liquidation pressure.
            sign = -1.0 if side == "SELL" else 1.0

            if mins <= 5:
                liq5 += notional
            if mins <= 15:
                liq15 += notional
                signed15 += sign * notional
            if mins <= 60:
                liq60 += notional

        if signed15 > 250000:
            pressure = "SHORT_LIQUIDATION_PRESSURE"
        elif signed15 < -250000:
            pressure = "LONG_LIQUIDATION_PRESSURE"
        else:
            pressure = "LIQUIDATIONS_NEUTRAL"

        return {
            "liq_5m": liq5,
            "liq_15m": liq15,
            "liq_60m": liq60,
            "signed_15m": signed15,
            "pressure": pressure,
        }

    def derivatives_state(self, cur, symbol, side):
        d = self.latest(cur, "latest_derivatives_regime_v10")
        if not d:
            return {
                "state": "DERIVATIVES_UNAVAILABLE",
                "confidence": 0.0,
                "side_conflict": 0,
                "score": 20.0,
            }

        selected_side = str(d.get("selected_side") or "").upper()
        confidence = f(d.get("confidence_score"))
        side_conflict = 1 if selected_side and selected_side != side else 0

        score = confidence
        if side_conflict:
            score = min(score, 25.0)
        if "CONFLICT" in str(d.get("derivatives_state") or ""):
            score = min(score, 25.0)

        return {
            "state": d.get("derivatives_state"),
            "confidence": confidence,
            "selected_side": selected_side,
            "side_conflict": side_conflict,
            "score": clamp(score, 0, 100),
            "raw": d,
        }

    def external_flow_state(self, cur, source):
        if not self.exists(cur, "alpha_external_flow_ingest_v16"):
            return "DATA_UNAVAILABLE_NOT_FAKED"

        row = cur.execute("""
            SELECT *
            FROM alpha_external_flow_ingest_v16
            WHERE source=?
            ORDER BY id DESC
            LIMIT 1;
        """, (source,)).fetchone()

        if not row:
            return "DATA_UNAVAILABLE_NOT_FAKED"

        return "DATA_AVAILABLE"

    def build_feature_store(self, cur):
        output = {}

        for symbol in self.symbols:
            for side in ["LONG", "SHORT"]:
                try:
                    b = self.fetch_binance_public(symbol)
                    liq = self.liquidation_aggregate(cur, symbol)
                    der = self.derivatives_state(cur, symbol, side)
                    etf = self.external_flow_state(cur, "ETF_FLOWS")
                    opt = self.external_flow_state(cur, "OPTIONS_FLOW")

                    quality = "REAL_BINANCE_PUBLIC"
                    if liq["pressure"] == "LIQUIDATIONS_UNAVAILABLE":
                        quality += "_NO_LIQ_STREAM"
                    if etf != "DATA_AVAILABLE":
                        quality += "_NO_ETF"
                    if opt != "DATA_AVAILABLE":
                        quality += "_NO_OPTIONS"

                    payload = {
                        "binance": b,
                        "liquidations": liq,
                        "derivatives": der,
                        "external_flows": {
                            "etf": etf,
                            "options": opt,
                        },
                    }

                    cur.execute("""
                        INSERT INTO alpha_feature_store_v16 (
                            ts, version, symbol, side, feature_quality,
                            mark_price, funding_rate, open_interest, spread_bps,
                            imbalance_5, imbalance_20, bid_depth_20, ask_depth_20,
                            depth_pressure, liquidation_5m_usd, liquidation_15m_usd,
                            liquidation_60m_usd, liquidation_signed_15m_usd,
                            liquidation_pressure, derivatives_state,
                            derivatives_confidence, derivatives_side_conflict,
                            etf_flow_state, options_flow_state, payload
                        )
                        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);
                    """, (
                        now_iso(), VERSION, symbol, side, quality,
                        b["mark_price"], b["funding_rate"], b["open_interest"],
                        b["spread_bps"], b["imbalance_5"], b["imbalance_20"],
                        b["bid_depth_20"], b["ask_depth_20"], b["depth_pressure"],
                        liq["liq_5m"], liq["liq_15m"], liq["liq_60m"], liq["signed_15m"],
                        liq["pressure"], der["state"], der["confidence"],
                        der["side_conflict"], etf, opt, js(payload),
                    ))

                    output[f"{symbol}_{side}"] = quality

                except Exception as e:
                    output[f"{symbol}_{side}"] = f"ERROR:{repr(e)}"

        self.record_contract(cur, "BINANCE_PUBLIC_OI_FUNDING_DEPTH", "REFRESHED", 100.0, output)
        self.record_contract(cur, "ETF_FLOWS", "DATA_UNAVAILABLE_NOT_FAKED", 0.0, {
            "reason": "Needs real external source. Not fabricated."
        })
        self.record_contract(cur, "OPTIONS_FLOW", "DATA_UNAVAILABLE_NOT_FAKED", 0.0, {
            "reason": "Needs real external source. Not fabricated."
        })

        return output

