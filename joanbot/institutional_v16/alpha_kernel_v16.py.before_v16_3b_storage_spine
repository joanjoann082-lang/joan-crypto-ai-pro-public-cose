            return []

    def latest(self, cur, name):
        if not self.exists(cur, name):
            return {}
        try:
            row = cur.execute(f"SELECT * FROM {name} LIMIT 1").fetchone()
            return dict(row) if row else {}
        except Exception:
            return {}

