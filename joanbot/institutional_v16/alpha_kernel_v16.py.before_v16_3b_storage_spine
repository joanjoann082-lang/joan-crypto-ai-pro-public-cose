    def exists(self, cur, name):
        return cur.execute(
            "SELECT COUNT(*) FROM sqlite_master WHERE name=?",
            (name,),
        ).fetchone()[0] > 0

    def cols(self, cur, table):
        try:
            return [r[1] for r in cur.execute(f"PRAGMA table_info({table})").fetchall()]
