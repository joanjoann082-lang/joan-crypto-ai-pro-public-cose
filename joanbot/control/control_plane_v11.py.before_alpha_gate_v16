from __future__ import annotations

import argparse
import json
from typing import Any, Dict, List

from joanbot.storage.db import get_db
from joanbot.utils import utc_now_iso

VERSION = "INSTITUTIONAL_CONTROL_PLANE_V11_3_SLIM_PERSISTENCE"


def fnum(x: Any, default: float = 0.0) -> float:
    try:
        if x is None:
            return default
        return float(x)
    except Exception:
        return default


def inum(x: Any, default: int = 0) -> int:
    try:
        if x is None:
            return default
        return int(float(x))
    except Exception:
        return default


def js(x: Any) -> str:
    return json.dumps(x, separators=(",", ":"), ensure_ascii=False, sort_keys=True, default=str)


DROP_PERSIST_KEYS = {
    "payload",
    "ordered_contract_json",
    "decision_contract_json",
    "contract_json",
    "raw_payload",
    "raw",
    "data_json",
}


def slim_value(x: Any, depth: int = 0) -> Any:
    if depth > 3:
        return "__DEPTH_LIMIT__"
    if isinstance(x, dict):
        out = {}
        for k, v in x.items():
            if str(k) in DROP_PERSIST_KEYS:
                out[str(k)] = "__DROPPED_HEAVY_FIELD__"
            else:
                out[str(k)] = slim_value(v, depth + 1)
        return out
    if isinstance(x, list):
        return [slim_value(v, depth + 1) for v in x[:20]]
    if isinstance(x, str):
        return x if len(x) <= 800 else x[:800] + "__TRUNCATED__"
    return x


def slim_row(row: Dict[str, Any]) -> Dict[str, Any]:
    return slim_value(row) if isinstance(row, dict) else {}


class InstitutionalControlPlaneV11:
    """
    One final authority after the ordered stimulus chain.

    The control plane does not ask the API, shadow, derivatives, or feedback
    modules independently to open. It consumes their ordered outputs and emits
    exactly one contract: block, wait, probe, reduced canary, or full canary.
    """

    def __init__(self, db=None) -> None:
        self.db = db or get_db()

    def ensure_schema(self) -> None:
        self.db.execute("""
            CREATE TABLE IF NOT EXISTS institutional_control_plane_v11 (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                ts TEXT NOT NULL,
                version TEXT NOT NULL,
                flow_hash TEXT NOT NULL,
                global_state TEXT NOT NULL,
                decision_tier TEXT NOT NULL,
                control_score REAL NOT NULL,
                confidence_score REAL NOT NULL,

                allow_standard_open INTEGER NOT NULL,
                allow_direct_open INTEGER NOT NULL,
                allow_paper_micro_canary INTEGER NOT NULL,
                force_learning_only INTEGER NOT NULL,
                veto_new_positions INTEGER NOT NULL,
                max_size_usd REAL NOT NULL,
                max_daily_canaries INTEGER NOT NULL,
                required_execution_mode TEXT NOT NULL,
                recommended_action TEXT NOT NULL,
                next_required_build TEXT NOT NULL,

                source_edge_id INTEGER NOT NULL,
                edge_symbol TEXT,
                edge_side TEXT,
                edge_family TEXT,
                edge_setup TEXT,
                edge_profile TEXT,
                edge_horizon_min INTEGER NOT NULL,
                edge_n INTEGER NOT NULL,
                edge_avg_r REAL NOT NULL,
                edge_lcb_r REAL NOT NULL,
                edge_recent20_avg_r REAL NOT NULL,
                edge_recent50_lcb_r REAL NOT NULL,
                edge_winrate REAL NOT NULL,
                robustness_score REAL NOT NULL,
                validation_state TEXT NOT NULL,

                shadow_regime_state TEXT NOT NULL,
                shadow_regime_score REAL NOT NULL,
                derivatives_state TEXT NOT NULL,
                derivatives_score REAL NOT NULL,
                derivatives_opposite_score REAL NOT NULL,
                derivatives_data_quality REAL NOT NULL,
                feedback_state TEXT NOT NULL,
                kpi_state TEXT NOT NULL,
                overlap_state TEXT NOT NULL,

                open_v11_canaries INTEGER NOT NULL,
                today_v11_canaries INTEGER NOT NULL,
                hard_vetoes TEXT NOT NULL,
                reasons TEXT NOT NULL,
                decision_contract_json TEXT NOT NULL,
                payload TEXT NOT NULL
            );
        """)
        self.db.execute("DROP VIEW IF EXISTS latest_institutional_control_plane_v11;")
        self.db.execute("""
            CREATE VIEW latest_institutional_control_plane_v11 AS
            SELECT * FROM institutional_control_plane_v11
            ORDER BY id DESC LIMIT 1;
        """)

    def q1(self, sql: str, params=()) -> Dict[str, Any]:
        try:
            rows = self.db.query(sql, params)
            return dict(rows[0]) if rows else {}
        except Exception:
            return {}

    def best_edge(self) -> Dict[str, Any]:
        return self.q1("""
            SELECT * FROM latest_edge_robustness_validator_v9
            ORDER BY canary_permission DESC, robustness_score DESC, lcb_r DESC, avg_r DESC, n DESC
            LIMIT 1;
        """)

    def open_v11_canaries(self) -> int:
        return inum(self.q1("SELECT COUNT(*) AS n FROM paper_micro_canary_positions_v11 WHERE status='OPEN';").get("n"))

    def today_v11_canaries(self) -> int:
        return inum(self.q1("""
            SELECT COUNT(*) AS n
            FROM paper_micro_canary_positions_v11
            WHERE substr(opened_at,1,10)=substr(datetime('now'),1,10);
        """).get("n"))

    def refresh(self) -> Dict[str, Any]:
        self.ensure_schema()
        edge = self.best_edge()
        shadow = self.q1("SELECT * FROM latest_regime_adaptive_router_v6;")
        deriv = self.q1("SELECT * FROM latest_derivatives_regime_v10;")
        feedback = self.q1("SELECT * FROM latest_micro_canary_outcome_feedback_v11;")
        kpi = self.q1("SELECT * FROM latest_micro_canary_kpi_v11;")
        overlap = self.q1("SELECT * FROM latest_overlap_guard_v11;")
        order = self.q1("""
            SELECT id, ts, version, phase, flow_hash, selected_symbol, selected_side,
                   selected_setup, selected_profile, selected_horizon_min,
                   source_edge_id, ordered_stage_count, missing_stage_count, hard_vetoes
            FROM latest_institutional_decision_order_v11;
        """)

        validation = str(edge.get("validation_state") or "NO_VALIDATED_EDGE")
        shadow_state = str(shadow.get("regime_state") or "NO_SHADOW_REGIME")
        derivatives_state = str(deriv.get("derivatives_state") or "NO_DERIVATIVES_REGIME")
        feedback_state = str(feedback.get("feedback_state") or "NO_FEEDBACK")
        kpi_state = str(kpi.get("kpi_state") or "NO_KPI")
        overlap_state = str(overlap.get("guard_state") or "NO_OVERLAP_GUARD")
        flow_hash = str(order.get("flow_hash") or "NO_FLOW_HASH")

        source_edge_id = inum(edge.get("source_edge_id"))
        side = str(edge.get("side") or "UNKNOWN").upper()
        edge_symbol = str(edge.get("symbol") or "")
        deriv_symbol = str(deriv.get("symbol") or "")
        deriv_side = str(deriv.get("selected_side") or "").upper()

        hard_vetoes: List[str] = []
        reasons: List[str] = []
        allow_micro = 0
        allow_standard = 0
        allow_direct = 0
        force_learning = 1
        veto_new = 1
        max_size = 0.0
        max_daily = 1
        mode = "NONE"
        tier = "BLOCK"
        action = "WAIT"
        next_build = "OBSERVE_ORDERED_PIPELINE"

        open_canaries = self.open_v11_canaries()
        today_canaries = self.today_v11_canaries()

        edge_ready = validation == "ROBUST_EDGE_READY" and inum(edge.get("canary_permission")) == 1
        robust_high = fnum(edge.get("robustness_score")) >= 90 and fnum(edge.get("lcb_r")) >= 0.07 and inum(edge.get("n")) >= 45
        recent_ok = fnum(edge.get("recent20_avg_r")) >= 0.0 and fnum(edge.get("recent50_lcb_r")) >= 0.0
        shadow_support = shadow_state == "REGIME_SUPPORTS_CLUSTER"
        shadow_mixed = shadow_state == "REGIME_MIXED_CLUSTER_REVIEW_ONLY"
        deriv_strong_confirm = derivatives_state.startswith("DERIVATIVES_CONFIRM_STRONG")
        deriv_confirm = derivatives_state.startswith("DERIVATIVES_CONFIRM")
        deriv_neutral_support = derivatives_state.startswith("DERIVATIVES_NEUTRAL_SUPPORTIVE")
        deriv_soft_conflict = derivatives_state.startswith("DERIVATIVES_SOFT_CONFLICT")
        deriv_conflict = derivatives_state.startswith("DERIVATIVES_CONFLICT") or inum(deriv.get("veto_canary")) == 1
        derivatives_quality = fnum(deriv.get("data_quality"))
        derivatives_regime_quality = fnum(deriv.get("regime_quality_score"), derivatives_quality)
        derivatives_confidence = fnum(deriv.get("confidence_score"))
        derivatives_contradiction = fnum(deriv.get("contradiction_index"))
        feedback_ok = feedback_state in ("NO_CANARY_HISTORY_OK", "CANARY_FEEDBACK_OK", "NO_FEEDBACK")
        kpi_ok_for_new = kpi_state in ("NO_KPI", "KPI_SAMPLE_TOO_SMALL", "KPI_HEALTHY")

        if inum(overlap.get("allow_v11_pipeline")) != 1:
            global_state = "OVERLAP_BLOCK"
            action = "NO_NEW_CANARY"
            next_build = "STOP_OLDER_EXECUTION_OR_MANAGE_OPEN_POSITION"
            hard_vetoes.append("OVERLAP_GUARD_BLOCK")
        elif open_canaries > 0:
            global_state = "MICRO_CANARY_ACTIVE"
            action = "MANAGE_EXISTING_V11_CANARY"
            next_build = "V11_FEEDBACK_AFTER_CLOSE"
            hard_vetoes.append("V11_CANARY_ALREADY_OPEN")
        elif today_canaries >= max_daily:
            global_state = "DAILY_CANARY_LIMIT_REACHED"
            action = "WAIT_NEXT_SESSION"
            next_build = "V11_FEEDBACK_AND_KPI"
            hard_vetoes.append("DAILY_CANARY_LIMIT_REACHED")
        elif not edge_ready:
            global_state = "LEARNING_ONLY" if validation != "ROBUST_EDGE_CANDIDATE" else "ROBUST_EDGE_CANDIDATE"
            action = "NO_CANARY"
            next_build = "EDGE_SAMPLE_EXPANSION_OR_ROBUSTNESS_RECHECK"
            hard_vetoes.append("NO_ROBUST_EDGE_READY")
        elif not recent_ok:
            global_state = "EDGE_RECENT_DECAY_BLOCK"
            action = "NO_CANARY"
            next_build = "WAIT_RECENT_EDGE_RECOVERY"
            hard_vetoes.append("EDGE_RECENT_METRICS_NOT_DEFENSIBLE")
        elif edge_symbol and deriv_symbol and edge_symbol != deriv_symbol:
            global_state = "PIPELINE_CONTRACT_MISMATCH"
            action = "NO_CANARY"
            next_build = "FIX_EDGE_DERIVATIVES_SYMBOL_ALIGNMENT"
            hard_vetoes.append("EDGE_DERIVATIVES_SYMBOL_MISMATCH")
        elif side in ("LONG", "SHORT") and deriv_side in ("LONG", "SHORT") and side != deriv_side:
            global_state = "PIPELINE_CONTRACT_MISMATCH"
            action = "NO_CANARY"
            next_build = "FIX_EDGE_DERIVATIVES_SIDE_ALIGNMENT"
            hard_vetoes.append("EDGE_DERIVATIVES_SIDE_MISMATCH")
        elif feedback_state == "CANARY_COOLDOWN":
            global_state = "CANARY_COOLDOWN"
            action = "NO_CANARY"
            next_build = "WAIT_FOR_CANARY_FEEDBACK_RECOVERY"
            hard_vetoes.append("CANARY_FEEDBACK_COOLDOWN")
        elif not kpi_ok_for_new:
            global_state = "KPI_RISK_BLOCK"
            action = "NO_CANARY"
            next_build = "KPI_RECOVERY_REQUIRED"
            hard_vetoes.append("KPI_STATE_BLOCKS_NEW_CANARY")
        elif deriv_conflict:
            global_state = "DERIVATIVES_CONFLICT_BLOCK"
            action = "WAIT_FOR_DERIVATIVES_CONFIRMATION"
            next_build = "DERIVATIVES_REGIME_MONITOR"
            hard_vetoes.append("DERIVATIVES_CONFLICTS_EDGE")
        elif deriv_soft_conflict:
            global_state = "DERIVATIVES_SOFT_CONFLICT_WAIT"
            action = "WAIT_FOR_DERIVATIVES_RECHECK"
            next_build = "DERIVATIVES_REGIME_MONITOR"
            hard_vetoes.append("DERIVATIVES_SOFT_CONFLICT")
        elif shadow_state == "REGIME_BLOCKS_CLUSTER":
            global_state = "SHADOW_REGIME_BLOCKED"
            action = "WAIT_FOR_SHADOW_REGIME_SUPPORT"
            next_build = "REGIME_RECHECK"
            hard_vetoes.append("SHADOW_REGIME_BLOCKS_EDGE")
        elif deriv_strong_confirm and shadow_support and robust_high and feedback_ok and derivatives_quality >= 70 and derivatives_regime_quality >= 65:
            global_state = "PAPER_MICRO_CANARY_FULL_READY"
            tier = "FULL_CANARY_50"
            action = "OPEN_ONE_V11_FULL_PAPER_MICRO_CANARY"
            allow_micro = 1
            force_learning = 0
            veto_new = 0
            max_size = 50.0
            mode = "PAPER_MICRO_CANARY_V11_FULL"
            reasons += ["ORDERED_PIPELINE_OK", "ROBUST_EDGE_HIGH", "SHADOW_SUPPORTS", "DERIVATIVES_STRONG_CONFIRM", "DATA_QUALITY_OK", "REGIME_QUALITY_OK"]
        elif deriv_confirm and shadow_support and robust_high and feedback_ok and derivatives_quality >= 65 and derivatives_regime_quality >= 55:
            global_state = "PAPER_MICRO_CANARY_REDUCED_READY"
            tier = "REDUCED_CANARY_25"
            action = "OPEN_ONE_V11_REDUCED_PAPER_MICRO_CANARY"
            allow_micro = 1
            force_learning = 0
            veto_new = 0
            max_size = 25.0
            mode = "PAPER_MICRO_CANARY_V11_REDUCED"
            reasons += ["ORDERED_PIPELINE_OK", "ROBUST_EDGE_HIGH", "SHADOW_SUPPORTS", "DERIVATIVES_CONFIRM", "REDUCED_SIZE_UNTIL_STRONG_CONFIRM"]
        elif deriv_confirm and shadow_mixed and feedback_ok and derivatives_quality >= 60 and derivatives_contradiction <= 55:
            global_state = "PAPER_MICRO_CANARY_PROBE_READY"
            tier = "PROBE_CANARY_15"
            action = "OPEN_ONE_V11_PROBE_PAPER_MICRO_CANARY"
            allow_micro = 1
            force_learning = 0
            veto_new = 0
            max_size = 15.0
            mode = "PAPER_MICRO_CANARY_V11_PROBE"
            reasons += ["ORDERED_PIPELINE_OK", "ROBUST_EDGE_READY", "SHADOW_MIXED", "DERIVATIVES_CONFIRM", "REDUCED_SIZE"]
        elif deriv_neutral_support and shadow_support and feedback_ok and derivatives_quality >= 60:
            global_state = "PAPER_MICRO_CANARY_REDUCED_READY"
            tier = "REDUCED_CANARY_25"
            action = "OPEN_ONE_V11_REDUCED_PAPER_MICRO_CANARY"
            allow_micro = 1
            force_learning = 0
            veto_new = 0
            max_size = 25.0
            mode = "PAPER_MICRO_CANARY_V11_REDUCED"
            reasons += ["ORDERED_PIPELINE_OK", "ROBUST_EDGE_READY", "SHADOW_SUPPORTS", "DERIVATIVES_NEUTRAL_SUPPORTIVE", "REDUCED_SIZE"]
        else:
            global_state = "WAIT_COMBINED_CONFIRMATION"
            action = "WAIT"
            next_build = "ACCUMULATE_ORDERED_EVIDENCE"
            hard_vetoes.append("NO_COMBINED_CONFIRMATION")

        edge_score = min(45.0, max(0.0, fnum(edge.get("lcb_r")) * 420.0) + min(12.0, fnum(edge.get("avg_r")) * 60.0))
        robust_score = min(20.0, fnum(edge.get("robustness_score")) * 0.20)
        shadow_score = 16.0 if shadow_support else 8.0 if shadow_mixed else 0.0
        deriv_score = min(16.0, max(0.0, fnum(deriv.get("selected_score")) - max(0.0, fnum(deriv.get("opposite_score")) * 0.35)) * 0.30 + min(4.0, derivatives_confidence * 0.04) - min(6.0, derivatives_contradiction * 0.06))
        feedback_score = 3.0 if feedback_ok else 0.0
        control_score = min(100.0, edge_score + robust_score + shadow_score + deriv_score + feedback_score)
        confidence_score = min(100.0, control_score * 0.75 + min(20.0, inum(edge.get("n")) * 0.25))

        contract = {
            "version": VERSION,
            "flow_hash": flow_hash,
            "global_state": global_state,
            "decision_tier": tier,
            "allow_standard_open": allow_standard,
            "allow_direct_open": allow_direct,
            "allow_paper_micro_canary": allow_micro,
            "required_execution_mode": mode,
            "max_size_usd": max_size,
            "max_daily_canaries": max_daily,
            "source_edge_id": source_edge_id,
            "symbol": edge.get("symbol"),
            "side": side,
            "hard_vetoes": hard_vetoes,
            "reasons": reasons,
            "paper_only": True,
            "paid_api_required": False,
            "single_final_authority": True,
        }
        payload = {
            "edge": slim_row(edge),
            "shadow_regime": slim_row(shadow),
            "derivatives_regime": slim_row(deriv),
            "feedback": slim_row(feedback),
            "kpi": slim_row(kpi),
            "overlap_guard": slim_row(overlap),
            "order_contract": slim_row(order),
            "decision_contract": slim_row(contract),
            "slim_persistence": True,
        }
        self.db.execute("""
            INSERT INTO institutional_control_plane_v11 (
                ts, version, flow_hash, global_state, decision_tier, control_score, confidence_score,
                allow_standard_open, allow_direct_open, allow_paper_micro_canary,
                force_learning_only, veto_new_positions, max_size_usd, max_daily_canaries,
                required_execution_mode, recommended_action, next_required_build,
                source_edge_id, edge_symbol, edge_side, edge_family, edge_setup, edge_profile, edge_horizon_min,
                edge_n, edge_avg_r, edge_lcb_r, edge_recent20_avg_r, edge_recent50_lcb_r,
                edge_winrate, robustness_score, validation_state,
                shadow_regime_state, shadow_regime_score, derivatives_state, derivatives_score,
                derivatives_opposite_score, derivatives_data_quality, feedback_state, kpi_state, overlap_state,
                open_v11_canaries, today_v11_canaries,
                hard_vetoes, reasons, decision_contract_json, payload
            ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);
        """, (
            utc_now_iso(), VERSION, flow_hash, global_state, tier, control_score, confidence_score,
            allow_standard, allow_direct, allow_micro, force_learning, veto_new, max_size, max_daily,
            mode, action, next_build,
            source_edge_id, edge.get("symbol"), edge.get("side"), edge.get("family_name"), edge.get("setup"), edge.get("profile"), inum(edge.get("horizon_min")),
            inum(edge.get("n")), fnum(edge.get("avg_r")), fnum(edge.get("lcb_r")), fnum(edge.get("recent20_avg_r")), fnum(edge.get("recent50_lcb_r")),
            fnum(edge.get("winrate")), fnum(edge.get("robustness_score")), validation,
            shadow_state, fnum(shadow.get("regime_score")), derivatives_state, fnum(deriv.get("selected_score")),
            fnum(deriv.get("opposite_score")), derivatives_quality, feedback_state, kpi_state, overlap_state,
            open_canaries, today_canaries,
            js(hard_vetoes), js(reasons), js(contract), js(payload),
        ))
        return {
            "version": VERSION,
            "flow_hash": flow_hash,
            "global_state": global_state,
            "decision_tier": tier,
            "allow_paper_micro_canary": allow_micro,
            "max_size_usd": max_size,
            "edge_symbol": edge.get("symbol"),
            "edge_side": edge.get("side"),
            "derivatives_state": derivatives_state,
            "shadow_regime_state": shadow_state,
            "hard_vetoes": hard_vetoes,
            "reasons": reasons,
        }


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--refresh", action="store_true")
    args = parser.parse_args()
    engine = InstitutionalControlPlaneV11()
    if args.refresh:
        print(json.dumps(engine.refresh(), indent=2, sort_keys=True, default=str))
    else:
        engine.ensure_schema()
        print(json.dumps({"version": VERSION, "schema": "ok"}, indent=2))


if __name__ == "__main__":
    main()
