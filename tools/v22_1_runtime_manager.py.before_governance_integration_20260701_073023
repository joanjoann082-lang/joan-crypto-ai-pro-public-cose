def utc() -> str:
    return datetime.now(timezone.utc).isoformat()

def sh(cmd: str) -> str:
    try:
        return subprocess.check_output(cmd, shell=True, text=True, stderr=subprocess.STDOUT)
    except subprocess.CalledProcessError as e:
        return e.output or ""

def load_state() -> Dict[str, Any]:
    if STATE.exists():
        try:
            return json.loads(STATE.read_text())
        except Exception:
            return {}
    return {}

def save_state(s: Dict[str, Any]) -> None:
    OUT.mkdir(parents=True, exist_ok=True)
    STATE.write_text(json.dumps(s, indent=2, sort_keys=True))

def pid_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
        return True
    except Exception:
        return False

def acquire_lock() -> bool:
    OUT.mkdir(parents=True, exist_ok=True)
    try:
        LOCKDIR.mkdir()
        (LOCKDIR / "pid").write_text(str(os.getpid()))
        (LOCKDIR / "ts").write_text(utc())
        return True
    except FileExistsError:
        try:
            pid = int((LOCKDIR / "pid").read_text().strip())
        except Exception:
            pid = 0
        if pid and pid_alive(pid):
            return False
        import shutil
        shutil.rmtree(LOCKDIR, ignore_errors=True)
        LOCKDIR.mkdir()
        (LOCKDIR / "pid").write_text(str(os.getpid()))
        (LOCKDIR / "ts").write_text(utc())
        return True

def release_lock() -> None:
    import shutil
    shutil.rmtree(LOCKDIR, ignore_errors=True)

def ps_rows(pattern: str) -> List[Dict[str, Any]]:
    out = sh("ps -ef")
    rows = []
    for line in out.splitlines():
        if "grep" in line:
            continue
        if re.search(pattern, line):
            parts = line.split()
            if len(parts) >= 2:
                try:
                    rows.append({"pid": int(parts[1]), "line": line})
                except Exception:
                    pass
    return rows

def kill(pid: int) -> bool:
    try:
        os.kill(pid, signal.SIGTERM)
        return True
    except Exception:
        return False

def rotate(path: Path) -> bool:
    try:
        if path.exists() and path.stat().st_size > LOG_MAX_MB * 1024 * 1024:
            backup = path.with_suffix(path.suffix + "." + datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S") + ".old")
            path.rename(backup)
            path.write_text("")
            return True
    except Exception:
        pass
    return False

def db_check() -> Dict[str, Any]:
    r = {"exists": DB.exists(), "size_mb": None, "quick_check": None, "error": None}
    if DB.exists():
        r["size_mb"] = round(DB.stat().st_size / 1024 / 1024, 2)
    else:
        r["error"] = "DB_MISSING"
        return r
    try:
        con = sqlite3.connect(str(DB), timeout=20)
        r["quick_check"] = con.execute("PRAGMA quick_check").fetchone()[0]
        con.close()
    except Exception as e:
        r["error"] = repr(e)
    return r

def restart_allowed(state: Dict[str, Any], name: str) -> bool:
    now_ts = time.time()
    h = state.setdefault("restart_history", {}).setdefault(name, [])
    h = [x for x in h if now_ts - x < 3600]
    state["restart_history"][name] = h
    return len(h) < MAX_RESTARTS_PER_HOUR

def mark_restart(state: Dict[str, Any], name: str) -> None:
    state.setdefault("restart_history", {}).setdefault(name, []).append(time.time())

def start_service(svc: Dict[str, Any]) -> Dict[str, Any]:
    script = ROOT / svc["script"]
    if not script.exists():
        return {"started": False, "reason": "SCRIPT_MISSING"}

    stdout = ROOT / svc["stdout"]
    stderr = ROOT / svc["stderr"]
    stdout.parent.mkdir(parents=True, exist_ok=True)
    stderr.parent.mkdir(parents=True, exist_ok=True)

    rotate(stdout)
    rotate(stderr)

    cmd = f'cd "{ROOT}" && export PYTHONPATH="$PWD" && nohup bash "{script}" >> "{stdout}" 2>> "{stderr}" &'
    subprocess.Popen(cmd, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    return {"started": True, "reason": "STARTED"}

def ensure_db_table(report: Dict[str, Any]) -> None:
    if not DB.exists():
        return
    try:
        con = sqlite3.connect(str(DB), timeout=30, isolation_level=None)
        con.execute("PRAGMA busy_timeout=30000")
        con.execute("""
        CREATE TABLE IF NOT EXISTS institutional_runtime_manager_health_v22_1 (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            ts TEXT,
            version TEXT,
            verdict TEXT,
            db_quick_check TEXT,
            enabled_count INTEGER,
            running_count INTEGER,
            restarted_count INTEGER,
            stopped_conflicts INTEGER,
            circuit_breakers INTEGER,
            problems TEXT,
            payload TEXT
        )
        """)
        con.execute("""
        INSERT INTO institutional_runtime_manager_health_v22_1
        (ts, version, verdict, db_quick_check, enabled_count, running_count,
         restarted_count, stopped_conflicts, circuit_breakers, problems, payload)
        VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
        """, (
            report["ts"], VERSION, report["verdict"], report["db"].get("quick_check"),
            report["enabled_count"], report["running_count"], report["restarted_count"],
            report["stopped_conflicts"], report["circuit_breakers"],
            json.dumps(report["problems"], sort_keys=True),
            json.dumps(report, sort_keys=True),
        ))
        con.close()
    except Exception:
        pass

def write_report(report: Dict[str, Any]) -> None:
    OUT.mkdir(parents=True, exist_ok=True)
    HEALTH.write_text(json.dumps(report, indent=2, sort_keys=True))

    lines = [
        f"# {VERSION}",
        f"- UTC: `{report['ts']}`",
        f"- Verdict: `{report['verdict']}`",
        f"- DB: `{report['db']}`",
        f"- Enabled: `{report['enabled_count']}`",
        f"- Running: `{report['running_count']}`",
        f"- Restarted: `{report['restarted_count']}`",
        f"- Stopped conflicts: `{report['stopped_conflicts']}`",
        f"- Circuit breakers: `{report['circuit_breakers']}`",
        f"- Problems: `{report['problems']}`",
        "",
        "## Services",
    ]
    for s in report["services"]:
        lines.append(
            f"- {s['name']} | enabled={s['enabled']} critical={s['critical']} "
            f"running={s['running']} action={s['action']} reason={s['reason']} pids={s['pids']}"
        )
    SUMMARY.write_text("\n".join(lines))

def manage_once() -> Dict[str, Any]:
    state = load_state()

    report = {
        "ts": utc(),
        "version": VERSION,
        "db": db_check(),
        "services": [],
        "enabled_count": 0,
        "running_count": 0,
        "restarted_count": 0,
        "stopped_conflicts": 0,
        "circuit_breakers": 0,
        "problems": [],
        "verdict": "UNKNOWN",
    }

    if report["db"].get("quick_check") != "ok":
        report["verdict"] = "BLOCKED_DB_NOT_OK"
        report["problems"].append("DB_NOT_OK_NO_SERVICE_RESTART")
        write_report(report)
        ensure_db_table(report)
        return report

    for svc in SERVICES:
        rows = ps_rows(svc["pattern"])
        item = {
            "name": svc["name"],
            "enabled": svc["enabled"],
            "critical": svc["critical"],
            "running": len(rows),
            "pids": [r["pid"] for r in rows],
            "action": "NONE",
            "reason": None,
        }

        if svc["enabled"]:
            report["enabled_count"] += 1

            if len(rows) == 0:
                if restart_allowed(state, svc["name"]):
                    res = start_service(svc)
                    item["action"] = "START"
                    item["reason"] = res["reason"]
                    if res["started"]:
                        mark_restart(state, svc["name"])
                        report["restarted_count"] += 1
                    elif svc["critical"]:
                        report["problems"].append(f"CRITICAL_START_FAILED:{svc['name']}:{res['reason']}")
                else:
                    item["action"] = "CIRCUIT_BREAKER"
                    item["reason"] = "MAX_RESTARTS_PER_HOUR"
                    report["circuit_breakers"] += 1
                    if svc["critical"]:
                        report["problems"].append(f"CRITICAL_CIRCUIT_BREAKER:{svc['name']}")

            elif len(rows) == 1:
                item["action"] = "OK"
                report["running_count"] += 1

            else:
                for extra in rows[1:]:
                    if kill(extra["pid"]):
                        report["stopped_conflicts"] += 1
                item["action"] = "DEDUP"
                item["reason"] = "KILLED_DUPLICATES"
                report["running_count"] += 1

        else:
            if len(rows) > 0:
                for r in rows:
                    if kill(r["pid"]):
                        report["stopped_conflicts"] += 1
                item["action"] = "STOP_DISABLED"
                item["reason"] = "DISABLED_TO_AVOID_OVERLAP"
            else:
                item["action"] = "DISABLED_OK"

        report["services"].append(item)

    save_state(state)

    report["verdict"] = "DEGRADED" if report["problems"] else "OK_RUNTIME_MANAGER_ACTIVE"
    write_report(report)
    ensure_db_table(report)
    return report

def daemon(interval: int) -> None:
    if not acquire_lock():
        print("V22_1_RUNTIME_MANAGER_ALREADY_RUNNING", flush=True)
        return
    try:
        while True:
            r = manage_once()
            print(
                f"{r['ts']} {VERSION} verdict={r['verdict']} running={r['running_count']} "
                f"restarted={r['restarted_count']} stopped={r['stopped_conflicts']} "
                f"cb={r['circuit_breakers']} problems={r['problems']}",
                flush=True,
            )
            time.sleep(interval)
    finally:
        release_lock()

def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--once", action="store_true")
    ap.add_argument("--daemon", action="store_true")
    ap.add_argument("--interval", type=int, default=60)
    args = ap.parse_args()

    if args.daemon:
        daemon(args.interval)
        return 0

    r = manage_once()
    print(SUMMARY.read_text())
    return 0 if r["verdict"] in ("OK_RUNTIME_MANAGER_ACTIVE", "DEGRADED") else 2

if __name__ == "__main__":
    raise SystemExit(main())
